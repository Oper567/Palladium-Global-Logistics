generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id        String   @id @default(cuid())
  name      String
  category  String
  basePrice String   
  status    String   @default("Available")
  imageUrl  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resources") 
}